# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Analytics only loads when this is set, so local/dev builds stay clean.
NEXT_PUBLIC_GA_ID=

# Contact form → Notion pipeline.
# 1. Create an internal integration at notion.so/profile/integrations
# 2. Share the "Website Inquiries" database with it
# 3. Paste the secret + the database ID here (and in Vercel env settings).
# The form returns a friendly "email us instead" message until these are set.
NOTION_API_KEY=
NOTION_INQUIRIES_DB_ID=
