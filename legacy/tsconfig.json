{
  "compilerOptions": {
    "outDir": "./dist/",
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "commonjs",
    "target": "es5",
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "removeComments": true,
    "noLib": false,
    "preserveConstEnums": true,
    "declaration": false,
    "suppressImplicitAnyIndexErrors": true,
    "experimentalDecorators": true,
    // "strictNullChecks": true,
    "typeRoots": ["node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@helpers/*": ["src/helpers/*"],
      "@components/*": ["src/components/*"]
    }
  },
  "filesGlob": ["./src/**/*.ts", "./src/**/*.tsx", "!./node_modules/**"],
  "files": ["./src/index.d.ts"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "config",
    "scripts",
    "acceptance-tests",
    "webpack",
    "jest",
    "src/jest-preprocess.js",
    "src/loadershim.js",
    "src/jest.config.js",
    "__mock__",
    "__tests__"
  ],
  "include": ["src/**/*"],
  "typeRoots": ["node_modules/@types", "src/types"]
}
